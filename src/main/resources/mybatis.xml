				<property name="driver" value="oracle.jdbc.OracleDriver"/>
		<property name="url" value="jdbc:oracle:thin:@localhost:1521:citysea"/>
		<property name="username" value="EXAM"/>
		<property name="password" value="123456"/>
			</dataSource> 
		</environment>
	</environments>
