		<mapper resource="/mapper/ScopePolicyRel.xml"/>
		<mapper resource="/mapper/PaperQuestionRel.xml"/>
		<mapper resource="/mapper/ExamStudentAnswer.xml"/>
		<mapper resource="/mapper/ExamStudentAnswerDetail.xml"/>
