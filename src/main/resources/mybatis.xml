	<mappers>
		<mapper resource="/mapper/SysUser.xml"/>
		<mapper resource="/mapper/SysRole.xml"/>
		<mapper resource="/mapper/SysRight.xml"/>
		<mapper resource="/mapper/ExamPolicy.xml"/>	
		<mapper resource="/mapper/ExamPolicyDetail.xml"/>
		<mapper resource="/mapper/ExamQuestion.xml"/>
		<mapper resource="/mapper/ExamKeyPoint.xml"/>
		<mapper resource="/mapper/ExamAnswer.xml"/>
		<mapper resource="/mapper/AppCourse.xml"/>
		<mapper resource="/mapper/AppScope.xml"/>
