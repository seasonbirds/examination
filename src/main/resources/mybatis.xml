<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE configuration PUBLIC "-//mybatis.org//DTD Config 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-config.dtd">
<configuration>
	<typeAliases>
		<typeAlias alias="SysUser" type="com.vnetoo.system.user.bo.SysUser"/>
		<typeAlias alias="SysRole" type="com.vnetoo.system.role.bo.SysRole"/>
		<typeAlias alias="SysRight" type="com.vnetoo.system.right.bo.SysRight"/>
		<typeAlias alias="ExamPolicy" type="com.vnetoo.examination.policy.bo.ExamPolicy"/>
		<typeAlias alias="ExamPolicyDetail" type="com.vnetoo.examination.policy.bo.ExamPolicyDetail"/>
		<typeAlias alias="ExamQuestion" type="com.vnetoo.examination.question.bo.ExamQuestion"/>
		<typeAlias alias="ExamKeyPoint" type="com.vnetoo.examination.keypoint.bo.ExamKeyPoint"/>
		<typeAlias alias="ExamAnswer" type="com.vnetoo.examination.question.bo.ExamAnswer"/>
		<typeAlias alias="AppCourse" type="com.vnetoo.examination.app.bo.AppCourse"/>
		<typeAlias alias="AppScope" type="com.vnetoo.examination.app.bo.AppScope"/>
		<typeAlias alias="ExamPaper" type="com.vnetoo.examination.paper.bo.ExamPaper"/>
		<typeAlias alias="ScopeCourseRel" type="com.vnetoo.examination.app.bo.ScopeCourseRel"/>
		<typeAlias alias="ScopeKeyPointRel" type="com.vnetoo.examination.app.bo.ScopeKeyPointRel"/>
		<typeAlias alias="ScopePolicyRel" type="com.vnetoo.examination.app.bo.ScopePolicyRel"/>
		<typeAlias alias="PaperQuestionRel" type="com.vnetoo.examination.paper.bo.PaperQuestionRel"/>
		<typeAlias alias="PaperQuestion" type="com.vnetoo.examination.paper.bo.PaperQuestion"/>
		<typeAlias alias="ExamStudentAnswer" type="com.vnetoo.examination.paper.bo.ExamStudentAnswer"/>
		<typeAlias alias="ExamStudentAnswerDetail" type="com.vnetoo.examination.paper.bo.ExamStudentAnswerDetail"/>
		<typeAlias alias="ScopeUserRel" type="com.vnetoo.examination.app.bo.ScopeUserRel"/>
		<typeAlias alias="MonitorInfo" type="com.vnetoo.examination.examMonitor.bo.MonitorInfo"/>
		<typeAlias alias="ExamReviewInfo" type="com.vnetoo.examination.examReview.bo.ExamReviewInfo"/>
		<typeAlias alias="BlobStringTypeHandler" type="com.vnetoo.common.typeHandler.BlobStringTypeHandler"/>
	</typeAliases>
	
	<typeHandlers>
		<typeHandler javaType="java.lang.String" jdbcType="BLOB" handler="BlobStringTypeHandler" />
	</typeHandlers>
	<plugins>
		<plugin interceptor="com.vnetoo.common.dao.PageInterceptor">
			<property name="pageHandler" value="com.vnetoo.common.dao.OraclePageHandler"/>
		</plugin>
	</plugins>
