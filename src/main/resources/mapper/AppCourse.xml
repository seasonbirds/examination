<?xml version="1.0" encoding="UTF-8" ?> 
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="AppCourse">
	
	<resultMap id="result" type="AppCourse">
		<result property="id" column="ID" jdbcType="NUMERIC"/>
		<result property="name" column="NAME" jdbcType="VARCHAR"/>	
	</resultMap>
	
	<insert id="insert" parameterType="AppScope">
	    <![CDATA[
			INSERT INTO APP_COURSE(
				ID,
				NAME
			)VALUES(
				#{id,jdbcType=NUMERIC},
				#{name,jdbcType=VARCHAR}
			)
	    ]]>
	</insert>
	
	<update id="update" parameterType="AppCourse">
		<![CDATA[
			UPDATE APP_COURSE SET 
				NAME=#{name}
			WHERE
				ID=#{id}
		]]>
	</update>
	
	<delete id="delete" parameterType="java.lang.Integer">
		<![CDATA[DELETE FROM APP_COURSE WHERE ID=#{id} ]]>
	</delete>	
	
	<select id="selectOne" parameterType="java.lang.Integer" resultMap="result">
		<![CDATA[
			SELECT *
			FROM 
				APP_COURSE
			WHERE
				ID=#{id}
		]]>
	</select>
	
	<select id="selectList" parameterType="AppCourse"  resultMap="result">
		<![CDATA[
			SELECT *
			FROM 
				APP_COURSE			
		]]>
		<where>
			<if test="id!=null" >
				AND ID=#{id}
			</if>
			<if test="name!=null" >
				AND upper(NAME) like upper('%${name}%')
			</if>
		</where>
			ORDER BY ID						
	</select>
	
	<select id="selectPage" resultMap="result">
		<![CDATA[
			SELECT 
				*
			FROM 
				APP_COURSE
			
		]]>
		<where>
			<if test="bo.id!=null" >
				AND ID=#{bo.id}
			</if>
			<if test="bo.name!=null" >
				AND upper(NAME) like upper('%${bo.name}%')
			</if>
		</where>	
			ORDER BY ${page.sortFieldName} <if test="page.sortDesc==true">DESC</if>
	</select>
	
	<select id="getCourseListByScopeId" parameterType="java.lang.Integer" resultMap="result">
		<![CDATA[
			SELECT 
				ID,NAME
			FROM 
				APP_COURSE,APP_SCOPE_COURSE_REL
			WHERE
				APP_SCOPE_COURSE_REL.SCOPE_ID = #{scopeId}
				AND APP_SCOPE_COURSE_REL.COURSE_ID = APP_COURSE.ID			
		]]>
	</select>
	
	<select id="getCourseIdListByScopeId" parameterType="java.lang.Integer" resultType="java.lang.Integer">
		<![CDATA[
			SELECT 
				COURSE_ID
			FROM 
				APP_SCOPE_COURSE_REL
			WHERE
				APP_SCOPE_COURSE_REL.SCOPE_ID = #{scopeId}
		]]>
	</select>
	
</mapper>



